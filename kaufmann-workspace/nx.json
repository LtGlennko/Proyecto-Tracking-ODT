{
  "$schema": "./node_modules/nx/schemas/nx-schema.json",
  "defaultBase": "main",
  "namedInputs": {
    "default": [
      "{projectRoot}/**/*",
      "sharedGlobals"
    ],
    "sharedGlobals": [],
    "production": [
      "default",
      "!{projectRoot}/**/*.spec.ts",
      "!{projectRoot}/tsconfig.spec.json"
    ]
  },
  "targetDefaults": {
    "build": {
      "dependsOn": [
        "^build"
      ],
      "inputs": [
        "production",
        "^production"
      ],
      "cache": true
    },
    "test": {
      "inputs": [
        "default",
        "^production"
      ],
      "cache": true
    },
    "lint": {
      "inputs": [
        "default",
        "^default"
      ],
      "cache": true
    }
  },
  "generators": {
    "@nx/angular:component": {
      "style": "none",
      "standalone": true,
      "changeDetection": "OnPush"
    },
    "@nx/angular:library": {
      "unitTestRunner": "jest"
    }
  },
  "plugins": [],
  "useLegacyCache": true
}
